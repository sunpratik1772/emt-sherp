{
  "schema_version": "1.0",
  "workflow_id": "fi_wash_trade_workflow",
  "name": "FI Wash Trade Surveillance",
  "version": "1.0",
  "description": "Detects wash trading in Fixed Income with counterparty circularity and price neutrality signals.",
  "nodes": [
    {
      "id": "n01",
      "type": "ALERT_TRIGGER",
      "label": "Alert Trigger",
      "config": {
        "alert_fields": {
          "trader_id": "string",
          "book": "string",
          "alert_date": "date",
          "currency_pair": "string",
          "entity": "string",
          "alert_id": "string"
        }
      }
    },
    {
      "id": "n02",
      "type": "EXECUTION_DATA_COLLECTOR",
      "label": "Collect Client Orders",
      "config": {
        "source": "hs_client_order",
        "query_template": "trader_id:\"{context.trader_id}\" AND book:\"{context.book}\" AND currency_pair:\"{context.currency_pair}\" AND order_date:\"{context.alert_date}\"",
        "output_name": "client_orders",
        "loop_over_books": true,
        "books": [
          "FI-GOVT",
          "FI-CORP"
        ]
      }
    },
    {
      "id": "n03",
      "type": "EXECUTION_DATA_COLLECTOR",
      "label": "Collect Executions",
      "config": {
        "source": "hs_execution",
        "query_template": "trader_id:\"{context.trader_id}\" AND book:\"{context.book}\" AND currency_pair:\"{context.currency_pair}\" AND trade_date:\"{context.alert_date}\" AND trade_version:1",
        "output_name": "executions",
        "loop_over_books": true,
        "books": [
          "FI-GOVT",
          "FI-CORP"
        ]
      }
    },
    {
      "id": "n04",
      "type": "FEATURE_ENGINE",
      "label": "Enrich Executions",
      "config": {
        "input_name": "executions",
        "output_name": "enriched_executions",
        "operations": [
          {
            "op": "derive_signed_notional"
          }
        ]
      }
    },
    {
      "id": "n05",
      "type": "COMMS_COLLECTOR",
      "label": "Collect Communications",
      "config": {
        "query_template": "user:\"{context.trader_id}\" AND date:\"{context.alert_date}\"",
        "keywords": [
          "wash",
          "offset",
          "back-to-back",
          "round-trip",
          "artificial volume",
          "related account",
          "step-out",
          "rotate",
          "coordinated"
        ],
        "output_name": "comms"
      }
    },
    {
      "id": "n06",
      "type": "SIGNAL_CALCULATOR",
      "label": "Wash Trade Signal",
      "config": {
        "mode": "configure",
        "signal_type": "WASH_TRADE",
        "input_name": "enriched_executions",
        "output_name": "wash_trade_signals",
        "params": {
          "window_minutes": 10,
          "ratio_threshold": 0.8
        }
      }
    },
    {
      "id": "n07",
      "type": "SIGNAL_CALCULATOR",
      "label": "Counterparty Circularity Signal",
      "config": {
        "mode": "upload_script",
        "input_name": "enriched_executions",
        "output_name": "counterparty_circularity_signals",
        "script_content": "import pandas as pd\nif 'counterparty' in df.columns and 'trader_id' in df.columns:\n    trader_id_val = df['trader_id'].iloc[0] if not df.empty else None\n    related = df['counterparty'].isin(['INTERNAL', 'RELATED', trader_id_val])\n    df['_signal_flag'] = related\n    df['_signal_score'] = related.astype(float) * 10\n    df['_signal_reason'] = df.apply(\n        lambda r: f\"Trade with related/internal counterparty: {r['counterparty']}\" if r['_signal_flag'] else \"\", axis=1\n    )\nelse:\n    df['_signal_flag'] = False\n    df['_signal_score'] = 0.0\n    df['_signal_reason'] = ''\ndf['_signal_type'] = 'COUNTERPARTY_CIRCULARITY'\ndf['_signal_window'] = '1d'"
      }
    },
    {
      "id": "n08",
      "type": "SIGNAL_CALCULATOR",
      "label": "Price Neutrality Signal",
      "config": {
        "mode": "upload_script",
        "input_name": "enriched_executions",
        "output_name": "price_neutrality_signals",
        "script_content": "import pandas as pd\nif 'signed_notional' in df.columns and not df.empty:\n    net_notional = df['signed_notional'].sum()\n    total_notional = df['signed_notional'].abs().sum()\n    neutrality = 1 - (abs(net_notional) / total_notional) if total_notional > 0 else 0\n    df['_signal_flag'] = neutrality > 0.9\n    df['_signal_score'] = round(neutrality * 10, 2)\n    df['_signal_reason'] = \"\"\n    if df['_signal_flag'].any():\n        df['_signal_reason'] = f\"Net notional neutrality: {neutrality:.2%}\"\nelse:\n    df['_signal_flag'] = False\n    df['_signal_score'] = 0.0\n    df['_signal_reason'] = ''\ndf['_signal_type'] = 'PRICE_NEUTRALITY'\ndf['_signal_window'] = '1d'"
      }
    },
    {
      "id": "n09",
      "type": "DATA_HIGHLIGHTER",
      "label": "Highlight Executions",
      "config": {
        "input_name": "wash_trade_signals",
        "output_name": "wash_trade_signals_highlighted",
        "rules": [
          {
            "condition": "_signal_flag == True",
            "colour": "#FF4444",
            "label": "WASH SIGNAL"
          },
          {
            "condition": "side == 'BUY'",
            "colour": "#90EE90",
            "label": "BUY"
          },
          {
            "condition": "side == 'SELL'",
            "colour": "#87CEEB",
            "label": "SELL"
          },
          {
            "condition": "status == 'CANCELLED'",
            "colour": "#FFD700",
            "label": "CANCELLED"
          }
        ]
      }
    },
    {
      "id": "n10",
      "type": "DATA_HIGHLIGHTER",
      "label": "Highlight Communications",
      "config": {
        "input_name": "comms",
        "output_name": "comms_highlighted",
        "rules": [
          {
            "condition": "_keyword_hit == True",
            "colour": "#FF8C00",
            "label": "COMM ALERT"
          }
        ]
      }
    },
    {
      "id": "n11",
      "type": "DECISION_RULE",
      "label": "Determine Disposition",
      "config": {
        "input_name": "wash_trade_signals",
        "escalate_threshold": 3,
        "review_threshold": 1
      }
    },
    {
      "id": "n12",
      "type": "SECTION_SUMMARY",
      "label": "Execution Analysis Section",
      "config": {
        "section_name": "execution_analysis",
        "input_name": "wash_trade_signals",
        "field_bindings": [
          {
            "field": "exec_quantity",
            "agg": "sum"
          },
          {
            "field": "signed_notional",
            "agg": "sum"
          },
          {
            "field": "_signal_flag",
            "agg": "count"
          }
        ],
        "llm_prompt_template": "Analyze execution patterns for {trader_id} in {currency_pair} related to wash trading. Key stats: {stats}. Disposition: {disposition}."
      }
    },
    {
      "id": "n13",
      "type": "SECTION_SUMMARY",
      "label": "Comms Analysis Section",
      "config": {
        "section_name": "comms_analysis",
        "input_name": "comms_highlighted",
        "field_bindings": [
          {
            "field": "_keyword_hit",
            "agg": "count"
          },
          {
            "field": "user",
            "agg": "nunique"
          }
        ],
        "llm_prompt_template": "Review communications for {trader_id} in {currency_pair}. Keyword hits: {stats}. Disposition: {disposition}."
      }
    },
    {
      "id": "n14",
      "type": "SECTION_SUMMARY",
      "label": "Counterparty Analysis Section",
      "config": {
        "section_name": "counterparty_analysis",
        "input_name": "counterparty_circularity_signals",
        "field_bindings": [
          {
            "field": "counterparty",
            "agg": "nunique"
          },
          {
            "field": "_signal_flag",
            "agg": "count"
          }
        ],
        "llm_prompt_template": "Examine counterparty relationships for {trader_id} during this period. Key stats: {stats}. Disposition: {disposition}."
      }
    },
    {
      "id": "n15",
      "type": "CONSOLIDATED_SUMMARY",
      "label": "Consolidated Executive Summary",
      "config": {
        "llm_prompt_template": null
      }
    },
    {
      "id": "n16",
      "type": "REPORT_OUTPUT",
      "label": "Generate Excel Report",
      "config": {
        "output_path": "output/fi_wash_trade_report_{context.alert_id}.xlsx",
        "tabs": [
          {
            "name": "Client Orders",
            "dataset": "client_orders",
            "include_highlights": false
          },
          {
            "name": "Executions",
            "dataset": "wash_trade_signals_highlighted",
            "include_highlights": true
          },
          {
            "name": "Comms",
            "dataset": "comms_highlighted",
            "include_highlights": true
          },
          {
            "name": "CParty Circularity",
            "dataset": "counterparty_circularity_signals",
            "include_highlights": false
          },
          {
            "name": "Price Neutrality",
            "dataset": "price_neutrality_signals",
            "include_highlights": false
          }
        ]
      }
    }
  ],
