{
  "workflow_id": "fx_front_running_t001_eur_usd",
  "name": "FX Front-Running for T001 EUR/USD",
  "schema_version": "1.0",
  "description": "Detects potential FX front-running activity for a specific trader and currency pair, combining trade, comms, and market data signals.",
  "nodes": [
    {
      "id": "n01",
      "type": "ALERT_TRIGGER",
      "label": "Alert Trigger",
      "config": {
        "alert_fields": {
          "trader_id": "string",
          "book": "string",
          "alert_date": "date",
          "currency_pair": "string",
          "alert_id": "string"
        }
      }
    },
    {
      "id": "n02",
      "type": "EXECUTION_DATA_COLLECTOR",
      "label": "Collect Client Orders",
      "config": {
        "source": "hs_client_order",
        "query_template": "trader_id:{context.trader_id} AND book:{context.book} AND currency_pair:\"{context.currency_pair}\" AND timestamp:[{context.alert_date}T00:00:00Z TO {context.alert_date}T23:59:59Z]",
        "output_name": "client_orders"
      }
    },
    {
      "id": "n03",
      "type": "EXECUTION_DATA_COLLECTOR",
      "label": "Collect Proprietary Executions",
      "config": {
        "source": "hs_execution",
        "query_template": "trader_id:{context.trader_id} AND book:{context.book} AND currency_pair:\"{context.currency_pair}\" AND timestamp:[{context.alert_date}T00:00:00Z TO {context.alert_date}T23:59:59Z] AND trade_version:1",
        "output_name": "prop_executions"
      }
    },
    {
      "id": "n04",
      "type": "FEATURE_ENGINE",
      "label": "Enrich Executions",
      "config": {
        "input_name": "prop_executions",
        "output_name": "enriched_executions",
        "operations": [
          {
            "op": "derive_signed_notional"
          }
        ]
      }
    },
    {
      "id": "n05",
      "type": "COMMS_COLLECTOR",
      "label": "Collect Communications",
      "config": {
        "query_template": "user:{context.trader_id} AND timestamp:[{context.alert_date}T00:00:00Z TO {context.alert_date}T23:59:59Z]",
        "keywords": [
          "fix",
          "benchmark",
          "front-run",
          "ahead",
          "before the move",
          "WM fix",
          "cover",
          "rotate",
          "push through",
          "client order",
          "step-out",
          "pull"
        ],
        "output_name": "comms_data"
      }
    },
    {
      "id": "n06",
      "type": "MARKET_DATA_COLLECTOR",
      "label": "Collect Market Data (EBS)",
      "config": {
        "source": "EBS",
        "query_template": "symbol:\"{context.currency_pair}\" AND timestamp:[{context.alert_date}T00:00:00Z TO {context.alert_date}T23:59:59Z]",
        "output_name": "market_data"
      }
    },
    {
      "id": "n07",
      "type": "SIGNAL_CALCULATOR",
      "label": "Front-Running Signal",
      "config": {
        "mode": "configure",
        "signal_type": "FRONT_RUNNING",
        "input_name": "enriched_executions",
        "output_name": "front_running_signals",
        "params": {
          "window_minutes": 5,
          "price_move_threshold": 0.0003
        }
      }
    },
    {
      "id": "n08",
      "type": "SIGNAL_CALCULATOR",
      "label": "Timing Correlation Signal",
      "config": {
        "mode": "upload_script",
        "input_name": "enriched_executions",
        "output_name": "timing_signals",
        "script_content": "import pandas as pd\nif all(c in df.columns for c in ['exec_time', 'order_time']):\n    df['order_time'] = pd.to_datetime(df['order_time'])\n    df['exec_time'] = pd.to_datetime(df['exec_time'])\n    df['_time_delta_mins'] = (\n        df['exec_time'] - df['order_time']\n    ).dt.total_seconds() / 60\n    df['_signal_flag'] = df['_time_delta_mins'].abs() < 3\n    df['_signal_score'] = (3 - df['_time_delta_mins'].clip(0, 3)).clip(0, 10).round(2)\n    df['_signal_reason'] = df.apply(\n        lambda r: f\"Prop trade {abs(r['_time_delta_mins']):.1f}m before client order\" if r['_signal_flag'] else \"\", axis=1\n    )\nelse:\n    df['_signal_flag'] = False\n    df['_signal_score'] = 0.0\n    df['_signal_reason'] = ''\ndf['_signal_type'] = 'TIMING_CORRELATION'\ndf['_signal_window'] = '3m'"
      }
    },
    {
      "id": "n09",
      "type": "DATA_HIGHLIGHTER",
      "label": "Highlight Client Orders",
      "config": {
        "input_name": "client_orders",
        "output_name": "client_orders_highlighted",
        "rules": [
          {
            "condition": "side == 'BUY'",
            "colour": "#90EE90",
            "label": "BUY"
          },
          {
            "condition": "side == 'SELL'",
            "colour": "#87CEEB",
            "label": "SELL"
          }
        ]
      }
    },
    {
      "id": "n10",
      "type": "DATA_HIGHLIGHTER",
      "label": "Highlight Prop Executions",
      "config": {
        "input_name": "front_running_signals",
        "output_name": "prop_executions_highlighted",
        "rules": [
          {
            "condition": "_signal_flag == True",
            "colour": "#FF4444",
            "label": "FRO SIGNAL"
          },
          {
            "condition": "side == 'BUY'",
            "colour": "#90EE90",
            "label": "BUY"
          },
          {
            "condition": "side == 'SELL'",
            "colour": "#87CEEB",
            "label": "SELL"
          }
        ]
      }
    },
    {
      "id": "n11",
      "type": "DATA_HIGHLIGHTER",
      "label": "Highlight Communications",
      "config": {
        "input_name": "comms_data",
        "output_name": "comms_highlighted",
        "rules": [
          {
            "condition": "_keyword_hit == True",
            "colour": "#FF8C00",
            "label": "COMM ALERT"
          }
        ]
      }
    },
    {
      "id": "n12",
      "type": "DATA_HIGHLIGHTER",
      "label": "Highlight Front-Running Signals",
      "config": {
        "input_name": "front_running_signals",
        "output_name": "front_running_signals_highlighted",
        "rules": [
          {
            "condition": "_signal_flag == True",
            "colour": "#FF4444",
            "label": "FRO SIGNAL"
          }
        ]
      }
    },
    {
      "id": "n13",
      "type": "DATA_HIGHLIGHTER",
      "label": "Highlight Timing Signals",
      "config": {
        "input_name": "timing_signals",
        "output_name": "timing_signals_highlighted",
        "rules": [
          {
            "condition": "_signal_flag == True",
            "colour": "#FF4444",
            "label": "FRO SIGNAL"
          }
        ]
      }
    },
    {
      "id": "n14",
      "type": "DECISION_RULE",
      "label": "Determine Disposition",
      "config": {
        "input_name": "front_running_signals",
        "flag_count_expr": "ctx.values['front_running_signals_flag_count'] + ctx.values['timing_signals_flag_count'] + ctx.values['comms_data_keyword_hit_count']",
        "escalate_threshold": 5,
        "review_threshold": 1,
        "output_branches": {}
      }
    },
    {
      "id": "n15",
      "type": "SECTION_SUMMARY",
      "label": "Trade Analysis Summary",
      "config": {
        "section_name": "trade_analysis",
        "input_name": "enriched_executions",
        "field_bindings": [
          {
            "field": "signed_notional",
            "agg": "sum"
          },
          {
            "field": "qty",
            "agg": "sum"
          },
          {
            "field": "book",
            "agg": "nunique"
          }
        ]
      }
    },
    {
      "id": "n16",
      "type": "SECTION_SUMMARY",
      "label": "Comms Analysis Summary",
      "config": {
        "section_name": "comms_analysis",
        "input_name": "comms_data",
        "field_bindings": [
          {
            "field": "_keyword_hit",
            "agg": "count"
          },
          {
            "field": "event_type",
            "agg": "nunique"
          }
        ]
      }
    },
    {
      "id": "n17",
      "type": "SECTION_SUMMARY",
      "label": "Market Analysis Summary",
      "config": {
        "section_name": "market_analysis",
        "input_name": "market_data",
        "field_bindings": [
          {
            "field": "spread_pips",
            "agg": "mean"
          },
          {
            "field": "mid",
            "agg": "mean"
          }
        ]
      }
    },
    {
      "id": "n18",
      "type": "CONSOLIDATED_SUMMARY",
      "label": "Executive Summary",
      "config": {}
    },
    {
      "id": "n19",
      "type": "REPORT_OUTPUT",
      "label": "Generate Excel Report",
      "config": {
        "output_path": "output/FRO_Report_{context.trader_id}_{context.currency_pair}_{context.alert_date}.xlsx",
        "tabs": [
          {
            "name": "Client Orders",
            "dataset": "client_orders_highlighted",
            "include_highlights": true
          },
          {
            "name": "Prop Executions",
            "dataset": "prop_executions_highlighted",
            "include_highlights": true
          },
          {
            "name": "Front-Running Signals",
            "dataset": "front_running_signals_highlighted",
            "include_highlights": true
          },
          {
            "name": "Timing Signals",
            "dataset": "timing_signals_highlighted",
            "include_highlights": true
          },
          {
            "name": "Communications",
            "dataset": "comms_highlighted",
            "include_highlights": true
          },
          {
            "name": "Market Data",
            "dataset": "market_data",
            "include_highlights": false
          }
        ]
      }
    }
  ],
