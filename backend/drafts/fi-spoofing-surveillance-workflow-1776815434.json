{
  "workflow_id": "fi_spoofing_workflow",
  "name": "FI Spoofing Surveillance Workflow",
  "schema_version": "1.0",
  "description": "Detects fixed income spoofing activity using order flow, executions, and communications.",
  "nodes": [
    {
      "id": "n01",
      "type": "ALERT_TRIGGER",
      "label": "Alert Trigger",
      "config": {
        "alert_fields": {
          "trader_id": "string",
          "book": "string",
          "alert_date": "date",
          "instrument": "string",
          "cusip": "string",
          "alert_id": "string"
        }
      }
    },
    {
      "id": "n02",
      "type": "EXECUTION_DATA_COLLECTOR",
      "label": "Collect Client Orders",
      "config": {
        "source": "hs_client_order",
        "query_template": "trader_id:{context.trader_id} AND book:{context.book} AND instrument:{context.instrument} AND order_time:[{context.alert_date}T00:00:00Z TO {context.alert_date}T23:59:59Z]",
        "output_name": "client_orders"
      }
    },
    {
      "id": "n03",
      "type": "EXECUTION_DATA_COLLECTOR",
      "label": "Collect Executions",
      "config": {
        "source": "hs_execution",
        "query_template": "trader_id:{context.trader_id} AND book:{context.book} AND instrument:{context.instrument} AND exec_time:[{context.alert_date}T00:00:00Z TO {context.alert_date}T23:59:59Z] AND trade_version:1",
        "output_name": "executions"
      }
    },
    {
      "id": "n04",
      "type": "FEATURE_ENGINE",
      "label": "Enrich Client Orders",
      "config": {
        "input_name": "client_orders",
        "output_name": "client_orders_enriched",
        "operations": [
          {
            "op": "lifecycle_event"
          }
        ]
      }
    },
    {
      "id": "n05",
      "type": "FEATURE_ENGINE",
      "label": "Enrich Executions",
      "config": {
        "input_name": "executions",
        "output_name": "executions_enriched",
        "operations": [
          {
            "op": "derive_signed_notional"
          }
        ]
      }
    },
    {
      "id": "n06",
      "type": "SIGNAL_CALCULATOR",
      "label": "SPOOFING Signal",
      "config": {
        "mode": "configure",
        "signal_type": "SPOOFING",
        "input_name": "client_orders_enriched",
        "output_name": "spoofing_signals",
        "params": {
          "cancel_ratio_threshold": 0.7,
          "window": "1d"
        }
      }
    },
    {
      "id": "n07",
      "type": "SIGNAL_CALCULATOR",
      "label": "Order Size Anomaly Signal",
      "config": {
        "mode": "upload_script",
        "input_name": "spoofing_signals",
        "output_name": "order_size_anomaly_signals",
        "script_content": "import pandas as pd\nif 'quantity' in df.columns and 'status' in df.columns:\n    avg_exec = df[df['status'] == 'FILLED']['quantity'].mean() if (df['status'] == 'FILLED').any() else 1\n    df['_size_ratio'] = df['quantity'] / avg_exec if avg_exec > 0 else 0\n    df['_signal_flag'] = (df['_size_ratio'] > 5) & (df['status'] == 'CANCELLED')\n    df['_signal_score'] = df['_size_ratio'].clip(0, 10).round(2)\n    df['_signal_reason'] = df.apply(\n        lambda r: f\"Cancelled order {r['_size_ratio']:.1f}x larger than avg execution\" if r['_signal_flag'] else \"\", axis=1\n    )\nelse:\n    df['_signal_flag'] = False\n    df['_signal_score'] = 0.0\n    df['_signal_reason'] = ''\ndf['_signal_type'] = 'ORDER_SIZE_ANOMALY'\ndf['_signal_window'] = '1d'"
      }
    },
    {
      "id": "n08",
      "type": "SIGNAL_CALCULATOR",
      "label": "Rapid Cancel Pattern Signal",
      "config": {
        "mode": "upload_script",
        "input_name": "order_size_anomaly_signals",
        "output_name": "rapid_cancel_signals",
        "script_content": "import pandas as pd\nif 'order_time' in df.columns and 'status' in df.columns:\n    df['order_time'] = pd.to_datetime(df['order_time'])\n    df_sorted = df.sort_values('order_time')\n    df_sorted['_next_time'] = df_sorted['order_time'].shift(-1)\n    df_sorted['_life_secs'] = (df_sorted['_next_time'] - df_sorted['order_time']).dt.total_seconds().fillna(999)\n    df = df_sorted\n    df['_signal_flag'] = (df['_life_secs'] < 30) & (df['status'] == 'CANCELLED')\n    df['_signal_score'] = (30 - df['_life_secs'].clip(0, 30)).clip(0, 10).round(2)\n    df['_signal_reason'] = df.apply(\n        lambda r: f\"Order cancelled after {r['_life_secs']:.0f}s\" if r['_signal_flag'] else \"\", axis=1\n    )\nelse:\n    df['_signal_flag'] = False\n    df['_signal_score'] = 0.0\n    df['_signal_reason'] = ''\ndf['_signal_type'] = 'RAPID_CANCEL'\ndf['_signal_window'] = '30s'"
      }
    },
    {
      "id": "n09",
      "type": "COMMS_COLLECTOR",
      "label": "Collect Communications",
      "config": {
        "query_template": "user:{context.trader_id} AND timestamp:[{context.alert_date}T00:00:00Z TO {context.alert_date}T23:59:59Z]",
        "keywords": [
          "spoof",
          "pull orders",
          "layer",
          "fake order",
          "manipulate",
          "depth",
          "pull the bid",
          "pull the offer",
          "flood the book",
          "step-out"
        ],
        "output_name": "comms"
      }
    },
    {
      "id": "n10",
      "type": "MARKET_DATA_COLLECTOR",
      "label": "Collect Market Data",
      "config": {
        "source": "EBS",
        "query_template": "symbol:{context.instrument} AND timestamp:[{context.alert_date}T00:00:00Z TO {context.alert_date}T23:59:59Z]",
        "output_name": "market_data"
      }
    },
    {
      "id": "n11",
      "type": "DATA_HIGHLIGHTER",
      "label": "Highlight Client Orders",
      "config": {
        "input_name": "rapid_cancel_signals",
        "output_name": "client_orders_highlighted",
        "rules": [
          {
            "condition": "_signal_flag == True",
            "colour": "#FF4444",
            "label": "SPOOF SIGNAL"
          },
          {
            "condition": "status == 'CANCELLED'",
            "colour": "#FFD700",
            "label": "CANCELLED"
          },
          {
            "condition": "order_type == 'LIMIT'",
            "colour": "#DDA0DD",
            "label": "LIMIT ORDER"
          }
        ]
      }
    },
    {
      "id": "n12",
      "type": "DATA_HIGHLIGHTER",
      "label": "Highlight Communications",
      "config": {
        "input_name": "comms",
        "output_name": "comms_highlighted",
        "rules": [
          {
            "condition": "_keyword_hit == True",
            "colour": "#FF8C00",
            "label": "COMM ALERT"
          }
        ]
      }
    },
    {
      "id": "n13",
      "type": "DECISION_RULE",
      "label": "Determine Disposition",
      "config": {
        "input_name": "rapid_cancel_signals",
        "escalate_threshold": 5,
        "review_threshold": 2,
        "output_branches": {
          "ESCALATE": "escalate_branch",
          "REVIEW": "review_branch",
          "DISMISS": "dismiss_branch"
        }
      }
    },
    {
      "id": "n14",
      "type": "SECTION_SUMMARY",
      "label": "Order Analysis Summary",
      "config": {
        "section_name": "order_analysis",
        "input_name": "rapid_cancel_signals",
        "field_bindings": [
          {
            "field": "quantity",
            "agg": "sum"
          },
          {
            "field": "status",
            "agg": "count"
          },
          {
            "field": "order_id",
            "agg": "nunique"
          }
        ]
      }
    },
    {
      "id": "n15",
      "type": "SECTION_SUMMARY",
      "label": "Execution Analysis Summary",
      "config": {
        "section_name": "execution_analysis",
        "input_name": "executions_enriched",
        "field_bindings": [
          {
            "field": "exec_quantity",
            "agg": "sum"
          },
          {
            "field": "exec_price",
            "agg": "mean"
          },
          {
            "field": "exec_id",
            "agg": "nunique"
          }
        ]
      }
    },
    {
      "id": "n16",
      "type": "SECTION_SUMMARY",
      "label": "Comms Analysis Summary",
      "config": {
        "section_name": "comms_analysis",
        "input_name": "comms_highlighted",
        "field_bindings": [
          {
            "field": "user",
            "agg": "nunique"
          },
          {
            "field": "_keyword_hit",
            "agg": "sum"
          }
        ]
      }
    },
    {
      "id": "n17",
      "type": "CONSOLIDATED_SUMMARY",
      "label": "Executive Summary",
      "config": {}
    },
    {
      "id": "n18",
      "type": "REPORT_OUTPUT",
      "label": "Generate Report",
      "config": {
        "output_path": "output/spoofing_report_{context.alert_id}.xlsx",
        "tabs": [
          {
            "name": "Client Orders",
            "dataset": "client_orders_highlighted",
            "include_highlights": true
          },
          {
            "name": "Executions",
            "dataset": "executions_enriched",
            "include_highlights": false
          },
          {
            "name": "Comms",
            "dataset": "comms_highlighted",
            "include_highlights": true
          },
          {
            "name": "Market Data",
            "dataset": "market_data",
            "include_highlights": false
          },
          {
            "name": "Signals",
            "dataset": "rapid_cancel_signals",
            "include_highlights": true
          }
        ]
      }
    }
  ],
