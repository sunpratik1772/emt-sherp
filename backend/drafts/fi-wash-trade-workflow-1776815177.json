{
  "workflow_id": "fi_wash_trade_workflow",
  "name": "FI Wash Trade Workflow",
  "schema_version": "1.0",
  "description": "Detects Fixed Income wash trading using built-in and custom signals for counterparty circularity and price neutrality.",
  "nodes": [
    {
      "id": "n01",
      "type": "ALERT_TRIGGER",
      "label": "Alert Trigger",
      "config": {
        "alert_fields": {
          "trader_id": "string",
          "book": "string",
          "alert_date": "date",
          "currency_pair": "string",
          "entity": "string",
          "alert_id": "string"
        }
      }
    },
    {
      "id": "n02",
      "type": "EXECUTION_DATA_COLLECTOR",
      "label": "Collect Client Orders",
      "config": {
        "source": "hs_client_order",
        "query_template": "trader_id:{context.trader_id} AND book:{context.book} AND order_time:[{context.alert_date}T00:00:00Z TO {context.alert_date}T23:59:59Z] AND currency_pair:\"{context.currency_pair}\"",
        "output_name": "client_orders"
      }
    },
    {
      "id": "n03",
      "type": "EXECUTION_DATA_COLLECTOR",
      "label": "Collect Executions",
      "config": {
        "source": "hs_execution",
        "query_template": "trader_id:{context.trader_id} AND book:{context.book} AND exec_time:[{context.alert_date}T00:00:00Z TO {context.alert_date}T23:59:59Z] AND currency_pair:\"{context.currency_pair}\" AND trade_version:1",
        "output_name": "raw_executions"
      }
    },
    {
      "id": "n04",
      "type": "FEATURE_ENGINE",
      "label": "Enrich Executions",
      "config": {
        "input_name": "raw_executions",
        "output_name": "enriched_executions",
        "operations": [
          {
            "op": "lifecycle_event"
          },
          {
            "op": "derive_signed_notional"
          }
        ]
      }
    },
    {
      "id": "n05",
      "type": "COMMS_COLLECTOR",
      "label": "Collect Communications",
      "config": {
        "query_template": "user:{context.trader_id} AND timestamp:[{context.alert_date}T00:00:00Z TO {context.alert_date}T23:59:59Z]",
        "keywords": [
          "wash",
          "offset",
          "back-to-back",
          "round-trip",
          "artificial volume",
          "related account",
          "step-out",
          "rotate",
          "coordinated"
        ],
        "output_name": "comms_data"
      }
    },
    {
      "id": "n06",
      "type": "SIGNAL_CALCULATOR",
      "label": "Wash Trade Signal",
      "config": {
        "mode": "configure",
        "signal_type": "WASH_TRADE",
        "input_name": "enriched_executions",
        "output_name": "wash_trade_signals",
        "params": {
          "window_minutes": 10,
          "ratio_threshold": 0.8
        }
      }
    },
    {
      "id": "n07",
      "type": "SIGNAL_CALCULATOR",
      "label": "Counterparty Circularity Signal",
      "config": {
        "mode": "upload_script",
        "input_name": "enriched_executions",
        "output_name": "counterparty_circularity_signals",
        "script_content": "import pandas as pd\nif 'counterparty' in df.columns and 'trader_id' in df.columns:\n    related = df['counterparty'].isin(['INTERNAL', 'RELATED', df['trader_id'].iloc[0]])\n    df['_signal_flag'] = related\n    df['_signal_score'] = related.astype(float) * 10\n    df['_signal_reason'] = df.apply(\n        lambda r: f\"Trade with related/internal counterparty: {r['counterparty']}\" if r['_signal_flag'] else \"\", axis=1\n    )\nelse:\n    df['_signal_flag'] = False\n    df['_signal_score'] = 0.0\n    df['_signal_reason'] = ''\ndf['_signal_type'] = 'COUNTERPARTY_CIRCULARITY'\ndf['_signal_window'] = '1d'"
      }
    },
    {
      "id": "n08",
      "type": "SIGNAL_CALCULATOR",
      "label": "Price Neutrality Signal",
      "config": {
        "mode": "upload_script",
        "input_name": "enriched_executions",
        "output_name": "price_neutrality_signals",
        "script_content": "import pandas as pd\nif 'signed_notional' in df.columns:\n    net_notional = df['signed_notional'].sum()\n    total_notional = df['signed_notional'].abs().sum()\n    neutrality = 1 - (abs(net_notional) / total_notional) if total_notional > 0 else 0\n    df['_signal_flag'] = neutrality > 0.9\n    df['_signal_score'] = round(neutrality * 10, 2)\n    df['_signal_reason'] = f\"Net notional neutrality: {neutrality:.2%}\" if df['_signal_flag'].any() else ''\nelse:\n    df['_signal_flag'] = False\n    df['_signal_score'] = 0.0\n    df['_signal_reason'] = ''\ndf['_signal_type'] = 'PRICE_NEUTRALITY'\ndf['_signal_window'] = '1d'"
      }
    },
    {
      "id": "n09",
      "type": "DATA_HIGHLIGHTER",
      "label": "Highlight Executions",
      "config": {
        "input_name": "enriched_executions",
        "output_name": "executions_highlighted",
        "rules": [
          {
            "condition": "df['wash_trade_signals__signal_flag'] == True or df['counterparty_circularity_signals__signal_flag'] == True or df['price_neutrality_signals__signal_flag'] == True",
            "colour": "#FF4444",
            "label": "WASH SIGNAL"
          },
          {
            "condition": "side == 'BUY'",
            "colour": "#90EE90",
            "label": "BUY"
          },
          {
            "condition": "side == 'SELL'",
            "colour": "#87CEEB",
            "label": "SELL"
          },
          {
            "condition": "status == 'CANCELLED'",
            "colour": "#FFD700",
            "label": "CANCELLED"
          }
        ]
      }
    },
    {
      "id": "n10",
      "type": "DATA_HIGHLIGHTER",
      "label": "Highlight Communications",
      "config": {
        "input_name": "comms_data",
        "output_name": "comms_highlighted",
        "rules": [
          {
            "condition": "_keyword_hit == True",
            "colour": "#FF8C00",
            "label": "COMM ALERT"
          }
        ]
      }
    },
    {
      "id": "n11",
      "type": "DECISION_RULE",
      "label": "Determine Disposition",
      "config": {
        "input_name": "wash_trade_signals",
        "escalate_threshold": 3,
        "review_threshold": 1,
        "output_branches": {
          "ESCALATE": "escalate_branch",
          "REVIEW": "review_branch",
          "DISMISS": "dismiss_branch"
        }
      }
    },
    {
      "id": "n12",
      "type": "SECTION_SUMMARY",
      "label": "Execution Analysis Summary",
      "config": {
        "section_name": "execution_analysis",
        "input_name": "executions_highlighted",
        "field_bindings": [
          {
            "field": "exec_id",
            "agg": "count"
          },
          {
            "field": "signed_notional",
            "agg": "sum"
          },
          {
            "field": "counterparty",
            "agg": "nunique"
          }
        ],
        "llm_prompt_template": "Analyze the execution data for {trader_id} in {currency_pair}. Focus on the buy/sell ratio, net notional, and counterparty breakdown. Highlight any patterns indicative of wash trading. Here are the stats: {stats}"
      }
    },
    {
      "id": "n13",
      "type": "SECTION_SUMMARY",
      "label": "Comms Analysis Summary",
      "config": {
        "section_name": "comms_analysis",
        "input_name": "comms_highlighted",
        "field_bindings": [
          {
            "field": "display_post",
            "agg": "count"
          },
          {
            "field": "_keyword_hit",
            "agg": "sum"
          }
        ],
        "llm_prompt_template": "Review the communications for {trader_id}. Identify any keyword hits related to wash trading or coordination. Summarize the content and context of these communications. Here are the stats: {stats}"
      }
    },
    {
      "id": "n14",
      "type": "SECTION_SUMMARY",
      "label": "Counterparty Analysis Summary",
      "config": {
        "section_name": "counterparty_analysis",
        "input_name": "executions_highlighted",
        "field_bindings": [
          {
            "field": "counterparty",
            "agg": "nunique"
          },
          {
            "field": "counterparty",
            "agg": "count"
          }
        ],
        "llm_prompt_template": "Analyze the counterparties involved in trades by {trader_id}. Identify any internal, related, or circular counterparty relationships that could facilitate wash trading. Here are the stats: {stats}"
      }
    },
    {
      "id": "n15",
      "type": "CONSOLIDATED_SUMMARY",
      "label": "Consolidated Executive Summary",
      "config": {}
    },
    {
      "id": "n16",
      "type": "REPORT_OUTPUT",
      "label": "Generate Excel Report",
      "config": {
        "output_path": "output/FI_Wash_Trade_Report_{context.alert_id}.xlsx",
        "tabs": [
          {
            "name": "Client Orders",
            "dataset": "client_orders",
            "include_highlights": false
          },
          {
            "name": "Executions",
            "dataset": "executions_highlighted",
            "include_highlights": true
          },
          {
            "name": "Wash Trade Signals",
            "dataset": "wash_trade_signals",
            "include_highlights": false
          },
          {
            "name": "Counterparty Signals",
            "dataset": "counterparty_circularity_signals",
            "include_highlights": false
          },
          {
            "name": "Price Neutrality Signals",
            "dataset": "price_neutrality_signals",
            "include_highlights": false
          },
          {
            "name": "Communications",
            "dataset": "comms_highlighted",
            "include_highlights": true
          }
        ]
      }
    }
  ],
