{
  "name": "fx_front_running",
  "description": "FX front-running detection chassis: TIME_WINDOW + collectors, GROUP_BY orders by book + MAP per-book aggregation, fact_pack_llm + event_narrative section summaries, expand_from per-book Excel routing.",
  "matches": {
    "scenarios": [
      "front-running",
      "front_running",
      "fro",
      "frontrun"
    ],
    "datasets": [
      "orders",
      "executions",
      "comms",
      "market"
    ],
    "semantics": [
      "trader",
      "time"
    ]
  },
  "parameters": [
    {
      "name": "trader_id",
      "type": "string",
      "required": true,
      "description": "Trader under review."
    },
    {
      "name": "currency_pair",
      "type": "string",
      "required": true,
      "description": "Instrument symbol (e.g. EUR/USD)."
    },
    {
      "name": "event_time",
      "type": "string",
      "required": true,
      "description": "Reference timestamp the alert window centres on."
    },
    {
      "name": "pre_minutes",
      "type": "integer",
      "required": false,
      "default": 30,
      "description": "Pre-event lookback (minutes)."
    },
    {
      "name": "post_minutes",
      "type": "integer",
      "required": false,
      "default": 30,
      "description": "Post-event lookahead (minutes)."
    }
  ],
  "skeleton": {
    "schema_version": "1.0",
    "workflow_id": "fx_fro_v2",
    "name": "FX Front-Running Detection (chassis v2)",
    "version": "2.0",
    "description": "FRO workflow rebuilt on the Phase 1-5 chassis: TIME_WINDOW + Solr Data Collector, per-book GROUP_BY + MAP fan-out, fact_pack_llm and event_narrative section modes, comms keyword categories, and expand_from per-book routing.",
    "nodes": [
      {
        "id": "n01",
        "type": "ALERT_TRIGGER",
        "label": "Alert Trigger",
        "config": {
          "alert_fields": {
            "trader_id": "string",
            "alert_date": "date",
            "currency_pair": "string",
            "alert_id": "string",
            "event_time": "string"
          }
        }
      },
      {
        "id": "n02",
        "type": "TIME_WINDOW",
        "label": "Alert Window",
        "config": {
          "event_time_key": "event_time",
          "pre_minutes": 30,
          "post_minutes": 30,
          "output_name": "window"
        }
      },
      {
        "id": "n03",
        "type": "EXECUTION_DATA_COLLECTOR",
        "label": "Collect Orders",
        "config": {
          "query_template": "trader_id:{context.trader_id}",
          "output_name": "orders",
          "window_key": "window",
          "source": "hs_client_order"
        }
      },
      {
        "id": "n04",
        "type": "EXECUTION_DATA_COLLECTOR",
        "label": "Collect Executions",
        "config": {
          "source": "hs_execution",
          "query_template": "trader_id:{context.trader_id} AND trade_version:1",
          "output_name": "executions",
          "window_key": "window"
        }
      },
      {
        "id": "n05",
        "type": "COMMS_COLLECTOR",
        "label": "Collect Communications",
        "config": {
          "query_template": "user:{context.trader_id}",
          "output_name": "comms",
          "window_key": "window",
          "keyword_categories": {
            "INTENT": [
              "layering",
              "spoofing",
              "front-run",
              "push through"
            ],
            "TIMING": [
              "fix",
              "WM fix",
              "benchmark",
              "before the move"
            ],
            "COVERUP": [
              "cover",
              "rotate",
              "step-out"
            ]
          },
          "emit_hits_only": true
        }
      },
      {
        "id": "n06",
        "type": "MARKET_DATA_COLLECTOR",
        "label": "Collect Market Ticks",
        "config": {
          "source": "EBS",
          "query_template": "symbol:{context.currency_pair}",
          "output_name": "market",
          "window_key": "window"
        }
      },
      {
        "id": "n07",
        "type": "GROUP_BY",
        "label": "Partition Orders by Book",
        "config": {
          "input_name": "orders",
          "group_by_column": "book",
          "output_prefix": "orders_by_book",
          "keys_output_name": "book_keys",
          "order": "sort"
        }
      },
      {
        "id": "n08",
        "type": "MAP",
        "label": "Per-Book Analysis",
        "config": {
          "keys_key": "book_keys",
          "iteration_ctx_key": "current_book",
          "dataset_prefix": "orders_by_book",
          "iteration_dataset_alias": "orders",
          "output_name": "per_book",
          "collect_values": [
            "book_qty_total",
            "book_order_count"
          ],
          "collect_datasets": [
            "orders"
          ],
          "sub_workflow": {
            "nodes": [
              {
                "id": "s1",
                "type": "EXTRACT_SCALAR",
                "label": "Book qty",
                "config": {
                  "input_name": "orders",
                  "column": "quantity",
                  "reducer": "sum",
                  "output_name": "book_qty_total"
                }
              },
              {
                "id": "s2",
                "type": "EXTRACT_SCALAR",
                "label": "Book order count",
                "config": {
                  "input_name": "orders",
                  "column": "order_id",
                  "reducer": "count",
                  "output_name": "book_order_count"
                }
              }
            ],
            "edges": [
              {
                "from": "s1",
                "to": "s2"
              }
            ]
          }
        }
      },
      {
        "id": "n09",
        "type": "SECTION_SUMMARY",
        "label": "Executions Fact Pack",
        "config": {
          "section_name": "executions_analysis",
          "input_name": "executions",
          "mode": "fact_pack_llm",
          "facts": [
            {
              "name": "exec_count",
              "column": "exec_id",
              "agg": "count"
            },
            {
              "name": "buy_count",
              "column": "side",
              "agg": "count_where_buy"
            },
            {
              "name": "sell_count",
              "column": "side",
              "agg": "count_where_sell"
            },
            {
              "name": "total_qty",
              "column": "exec_quantity",
              "agg": "sum"
            },
            {
              "name": "venues_touched",
              "column": "venue",
              "agg": "unique_values"
            }
          ],
          "required_facts": [
            "exec_count",
            "total_qty"
          ],
          "llm_prompt_template": "You are a trade surveillance analyst.\nTrader: {trader_id}  Disposition: {disposition}\nFacts (JSON):\n{facts}\n\nWrite a tight 2-paragraph narrative referencing every fact verbatim."
        }
      },
      {
        "id": "n10",
        "type": "SECTION_SUMMARY",
        "label": "Comms Event Narrative",
        "config": {
          "section_name": "comms_narrative",
          "input_name": "comms_hits",
          "mode": "event_narrative",
          "sort_by": "timestamp",
          "event_template": "{timestamp}  [{event_type}] {display_post}  (categories: {_matched_categories})",
          "max_events": 20,
          "llm_prompt_template": "Below is a chronological list of flagged comms for trader {trader_id}.\n{events}\n\nWrite a single-paragraph narrative weaving the events into a story. Be specific about timing."
        }
      },
      {
        "id": "n11",
        "type": "CONSOLIDATED_SUMMARY",
        "label": "Executive Summary",
        "config": {}
      },
      {
        "id": "n12",
        "type": "REPORT_OUTPUT",
        "label": "Generate Excel Report",
        "config": {
          "output_path": "output/fx_fro_v2_report.xlsx",
          "tabs": [
            {
              "name": "All Orders",
              "dataset": "orders",
              "include_highlights": false
            },
            {
              "name": "Executions",
              "dataset": "executions",
              "include_highlights": false
            },
            {
              "name": "Comms Hits",
              "dataset": "comms_hits",
              "include_highlights": false
            },
            {
              "name": "Market",
              "dataset": "market",
              "include_highlights": false
            },
            {
              "expand_from": "{context.per_book}",
              "as": "key",
              "name": "Book {key} Orders",
              "dataset": "per_book_{key}_orders",
              "include_highlights": false
            }
          ]
        }
      }
    ],
    "edges": [
      {
        "from": "n01",
        "to": "n02"
      },
      {
        "from": "n02",
        "to": "n03"
      },
      {
        "from": "n02",
        "to": "n04"
      },
      {
        "from": "n02",
        "to": "n05"
      },
      {
        "from": "n02",
        "to": "n06"
      },
      {
        "from": "n03",
        "to": "n07"
      },
      {
        "from": "n07",
        "to": "n08"
      },
      {
        "from": "n04",
        "to": "n09"
      },
      {
        "from": "n05",
        "to": "n10"
      },
      {
        "from": "n09",
        "to": "n11"
      },
      {
        "from": "n10",
        "to": "n11"
      },
      {
        "from": "n08",
        "to": "n12"
      },
      {
        "from": "n11",
        "to": "n12"
      }
    ]
  }
}
