{
  "schema_version": "1.0",
  "workflow_id": "fi_wash_001",
  "name": "Fixed Income Wash Trade Detection",
  "version": "1.0",
  "description": "Detects wash trading in fixed income \u2014 offsetting buy/sell transactions between related accounts to create artificial volume",
  "nodes": [
    {
      "id": "n01",
      "type": "ALERT_TRIGGER",
      "label": "Alert Trigger",
      "config": {
        "alert_fields": {
          "trader_id": "string",
          "book": "string",
          "alert_date": "date",
          "instrument": "string",
          "cusip": "string",
          "alert_id": "string"
        }
      }
    },
    {
      "id": "n02",
      "type": "EXECUTION_DATA_COLLECTOR",
      "label": "Collect Order Book",
      "config": {
        "source": "hs_client_order",
        "query_template": "trader_id:{context.trader_id} AND book:{context.book} AND order_time:[{context.alert_date}T00:00:00Z TO {context.alert_date}T23:59:59Z]",
        "output_name": "orders",
        "loop_over_books": false
      }
    },
    {
      "id": "n03",
      "type": "EXECUTION_DATA_COLLECTOR",
      "label": "Collect All Executions",
      "config": {
        "source": "hs_execution",
        "query_template": "trader_id:{context.trader_id} AND book:{context.book} AND exec_time:[{context.alert_date}T00:00:00Z TO {context.alert_date}T23:59:59Z] AND trade_version:1",
        "output_name": "executions",
        "loop_over_books": true,
        "books": [
          "FI-CREDIT",
          "FI-RATES",
          "FI-GOVT"
        ]
      }
    },
    {
      "id": "n04",
      "type": "COMMS_COLLECTOR",
      "label": "Collect Communications",
      "config": {
        "query_template": "user:{context.trader_id} AND timestamp:[{context.alert_date}T00:00:00Z TO {context.alert_date}T23:59:59Z]",
        "keywords": [
          "wash",
          "offset",
          "back-to-back",
          "round-trip",
          "volume",
          "artificial",
          "related account",
          "step-out",
          "rotate"
        ],
        "output_name": "comms_data"
      }
    },
    {
      "id": "n05",
      "type": "FEATURE_ENGINE",
      "label": "Normalise Executions",
      "config": {
        "input_name": "executions",
        "output_name": "executions_enriched",
        "ops": [
          {"op": "lifecycle_event", "group_by": "order_id", "sort_by": "exec_time", "status_col": "side"},
          {"op": "apply_expr", "out_col": "signed_notional", "expr": "(exec_quantity * exec_price) * (1 if side == 'BUY' else -1)"}
        ]
      }
    },
    {
      "id": "n06",
      "type": "SIGNAL_CALCULATOR",
      "label": "Wash Trade Signal",
      "config": {
        "mode": "configure",
        "signal_type": "WASH_TRADE",
        "input_name": "executions_enriched",
        "output_name": "signals",
        "params": {
          "window_minutes": 10,
          "ratio_threshold": 0.8
        }
      }
    },
    {
      "id": "n07",
      "type": "DECISION_RULE",
      "label": "Disposition Router",
      "config": {
        "input_name": "signals",
        "flag_count_expr": "flag_count > 0",
        "escalate_threshold": 3,
        "review_threshold": 1,
        "output_branches": {
          "ESCALATE": "escalate_branch",
          "REVIEW": "review_branch",
          "DISMISS": "dismiss_branch"
        }
      }
    },
    {
      "id": "n08",
      "type": "DATA_HIGHLIGHTER",
      "label": "Highlight Wash Rows",
      "config": {
        "input_name": "signals",
        "output_name": "signals_highlighted",
        "rules": [
          {
            "condition": "_signal_flag == True",
            "colour": "#FF4444",
            "label": "WASH SIGNAL"
          },
          {
            "condition": "side == 'BUY'",
            "colour": "#90EE90",
            "label": "BUY"
          },
          {
            "condition": "side == 'SELL'",
            "colour": "#87CEEB",
            "label": "SELL"
          }
        ]
      }
    },
    {
      "id": "n09",
      "type": "SECTION_SUMMARY",
      "label": "Execution Analysis Section",
      "config": {
        "section_name": "execution_analysis",
        "input_name": "signals",
        "field_bindings": [
          {
            "field": "exec_quantity",
            "agg": "sum"
          },
          {
            "field": "signed_notional",
            "agg": "sum"
          },
          {
            "field": "counterparty",
            "agg": "nunique"
          },
          {
            "field": "venue",
            "agg": "nunique"
          }
        ],
        "llm_prompt_template": "You are a senior financial surveillance analyst.\n\nAnalyse the following FI execution statistics for potential wash trading:\n\nTrader: {trader_id}\nDisposition: {disposition}\n\nStatistics:\n{stats}\n\nWrite a focused 2-paragraph analysis identifying wash trade patterns."
      }
    },
    {
      "id": "n10",
      "type": "SECTION_SUMMARY",
      "label": "Communications Analysis Section",
      "config": {
        "section_name": "comms_analysis",
        "input_name": "comms_data",
        "field_bindings": [
          {
            "field": "display_post",
            "agg": "count"
          },
          {
            "field": "_keyword_hit",
            "agg": "sum"
          }
        ],
        "llm_prompt_template": "You are a senior financial surveillance analyst.\n\nReview communications for wash trade coordination evidence:\n\nTrader: {trader_id}\nDisposition: {disposition}\n\nStatistics:\n{stats}\n\nWrite a 2-paragraph summary of communication patterns."
      }
    },
    {
      "id": "n11",
      "type": "CONSOLIDATED_SUMMARY",
      "label": "Executive Summary",
      "config": {}
    },
    {
      "id": "n12",
      "type": "REPORT_OUTPUT",
      "label": "Generate Excel Report",
      "config": {
        "output_path": "output/fi_wash_report.xlsx",
        "tabs": [
          {
            "name": "Orders",
            "dataset": "orders",
            "include_highlights": true
          },
          {
            "name": "Executions",
            "dataset": "executions_enriched",
            "include_highlights": true
          },
          {
            "name": "Signals",
            "dataset": "signals",
            "include_highlights": true
          },
          {
            "name": "Communications",
            "dataset": "comms_data",
            "include_highlights": true
          }
        ]
      }
    }
  ],
  "edges": [
    {
      "from": "n01",
      "to": "n02"
    },
    {
      "from": "n01",
      "to": "n03"
    },
