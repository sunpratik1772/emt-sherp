{
  "schema_version": "1.0",
  "workflow_id": "fro_chassis_ref_001",
  "name": "FRO Chassis Reference (TIME_WINDOW \u2192 ORDER \u2192 MAP \u2192 report)",
  "description": "Reference DAG using chassis nodes: time window, Solr order collection, trade data, GROUP_BY+MAP, signal, templated section, consolidated, decision, report with map_tab_sets. CSV paths use FIXTURES/ prefix; tests resolve to backend/tests/fixtures/.",
  "nodes": [
    {
      "id": "n01",
      "type": "ALERT_TRIGGER",
      "label": "Alert",
      "config": {
        "alert_fields": {
          "trader_id": "string",
          "book": "string",
          "alert_date": "date",
          "currency_pair": "string",
          "alert_id": "string",
          "fr_start": "string",
          "fr_end": "string"
        }
      }
    },
    {
      "id": "n02",
      "type": "TIME_WINDOW",
      "label": "Event window",
      "config": {
        "output_name": "window",
        "event_time_key": "fr_start",
        "end_time_key": "fr_end",
        "pre_minutes": 0,
        "post_minutes": 0
      }
    },
    {
      "id": "n03",
      "type": "EXECUTION_DATA_COLLECTOR",
      "label": "Orders",
      "config": {
        "output_name": "orders",
        "query_template": "trader_id:{context.trader_id}",
        "window_key": "window",
        "trader_filter_key": "trader_id",
        "mock_csv_path": "FIXTURES/fro/orders_fro.csv",
        "source": "hs_client_order"
      }
    },
    {
      "id": "n04",
      "type": "EXECUTION_DATA_COLLECTOR",
      "label": "Executions",
      "config": {
        "source": "hs_execution",
        "output_name": "executions",
        "query_template": "trader_id:{context.trader_id} AND trade_version:1",
        "window_key": "window",
        "mock_csv_path": "FIXTURES/fro/executions_fro.csv"
      }
    },
    {
      "id": "n05",
      "type": "FEATURE_ENGINE",
      "label": "Enrich",
      "config": {
        "input_name": "executions",
        "output_name": "executions_n",
        "ops": [
          {
            "op": "apply_expr",
            "out_col": "signed_notional",
            "expr": "notional_usd * (-1 if side == 'SELL' else 1)"
          }
        ]
      }
    },
    {
      "id": "n06",
      "type": "SIGNAL_CALCULATOR",
      "label": "FRO signal",
      "config": {
        "mode": "configure",
        "signal_type": "FRONT_RUNNING",
        "input_name": "executions_n",
        "output_name": "signals",
        "params": {
          "window_minutes": 5,
          "price_move_threshold": 0.0003
        }
      }
    },
    {
      "id": "n07",
      "type": "GROUP_BY",
      "label": "By book",
      "config": {
        "input_name": "orders",
        "group_by_column": "book",
        "output_prefix": "ord",
        "keys_output_name": "order_books"
      }
    },
    {
      "id": "n08",
      "type": "MAP",
      "label": "Per book count",
      "config": {
        "keys_key": "order_books",
        "iteration_ctx_key": "book_key",
        "dataset_prefix": "ord",
        "iteration_dataset_alias": "slice",
        "output_name": "per_book",
        "collect_datasets": [
          "slice"
        ],
        "collect_values": [
          "row_c"
        ],
        "sub_workflow": {
          "nodes": [
            {
              "id": "sm1",
              "type": "EXTRACT_SCALAR",
              "label": "rows in slice",
              "config": {
                "input_name": "slice",
                "column": "order_id",
                "reducer": "count",
                "output_name": "row_c"
              }
            }
          ],
          "edges": []
        }
      }
    },
    {
      "id": "n09",
      "type": "DATA_HIGHLIGHTER",
      "label": "Highlight",
      "config": {
        "input_name": "signals",
        "output_name": "signals_h",
        "rules": [
          {
            "condition": "_signal_flag == True",
            "colour": "#FF4444",
            "label": "SIGNAL"
          }
        ]
      }
    },
    {
      "id": "n10",
      "type": "DECISION_RULE",
      "label": "Decision",
      "config": {
        "input_name": "signals",
        "flag_count_expr": "flag_count > 0",
        "escalate_threshold": 100,
        "review_threshold": 1,
        "output_branches": {
          "REVIEW": "r",
          "DISMISS": "d",
          "ESCALATE": "e"
        }
      }
    },
    {
      "id": "n11",
      "type": "SECTION_SUMMARY",
      "label": "Trade section",
      "config": {
        "section_name": "trade",
        "input_name": "signals",
        "summary_mode": "templated",
        "llm_prompt_template": "Trader {trader_id} {currency_pair} rows={stats}"
      }
    },
    {
      "id": "n12",
      "type": "CONSOLIDATED_SUMMARY",
      "label": "Exec summary",
      "config": {
        "use_section_facts": true
      }
    },
    {
      "id": "n13",
      "type": "REPORT_OUTPUT",
      "label": "Report",
      "config": {
        "output_path": "output/fro_chassis_reference.xlsx",
        "summary_position": "first",
        "tabs": [
          {
            "name": "Orders",
            "dataset": "orders",
            "include_highlights": false
          },
          {
            "name": "Signals",
            "dataset": "signals_h",
            "include_highlights": false
          }
        ],
        "map_tab_sets": [
          {
            "map_value_key": "per_book",
            "dataset_prefix": "per_book",
            "datasets": [
              "slice"
            ]
          }
        ]
      }
    }
  ],
  "edges": [
    {
      "from": "n01",
      "to": "n02"
    },
    {
      "from": "n01",
      "to": "n03"
    },
    {
      "from": "n01",
      "to": "n04"
    },
    {
      "from": "n02",
      "to": "n03"
    },
    {
      "from": "n02",
      "to": "n04"
    },
    {
      "from": "n04",
      "to": "n05"
    },
    {
      "from": "n05",
      "to": "n06"
    },
    {
      "from": "n03",
      "to": "n07"
    },
    {
      "from": "n07",
      "to": "n08"
    },
    {
      "from": "n06",
      "to": "n09"
    },
    {
      "from": "n06",
      "to": "n10"
    },
    {
      "from": "n06",
      "to": "n11"
    },
    {
      "from": "n11",
      "to": "n12"
    },
    {
      "from": "n10",
      "to": "n13"
    },
    {
      "from": "n12",
      "to": "n13"
    },
    {
      "from": "n08",
      "to": "n13"
    },
    {
      "from": "n09",
      "to": "n13"
    }
  ]
}
