{
  "schema_version": "1.0",
  "workflow_id": "fisl_v1",
  "name": "Fixed Income Spoof / Layering (FISL) \u2014 nested MAP proof",
  "version": "1.1",
  "description": "FISL scenario built entirely on Phase 1-5 chassis primitives. Demonstrates nested MAP (outer venue, inner book), FEATURE_ENGINE (window_bucket \u2192 groupby_agg \u2192 pivot for an order-book ladder), shared SIGNAL_CALCULATOR (signal_type=SPOOFING), DATA_HIGHLIGHTER with cross-dataset refs, DECISION_RULE rules-mode + severity, SECTION_SUMMARY in three modes, and REPORT_OUTPUT with static + dynamic per-venue tabs (expand_from). Same node set, different config from FXFRO \u2014 proves cross-scenario portability with zero new node code.",
  "nodes": [
    {
      "id": "n01",
      "type": "ALERT_TRIGGER",
      "label": "Alert Trigger",
      "config": {
        "alert_fields": {
          "trader_id": "string",
          "alert_date": "date",
          "alert_id": "string",
          "event_time": "string"
        }
      }
    },
    {
      "id": "n02",
      "type": "TIME_WINDOW",
      "label": "Alert Window",
      "config": {
        "event_time_key": "event_time",
        "pre_minutes": 15,
        "post_minutes": 15,
        "output_name": "window"
      }
    },
    {
      "id": "n03",
      "type": "EXECUTION_DATA_COLLECTOR",
      "label": "Collect Orders",
      "config": {
        "query_template": "trader_id:{context.trader_id}",
        "output_name": "orders",
        "window_key": "window",
        "source": "hs_client_order"
      }
    },
    {
      "id": "n04",
      "type": "GROUP_BY",
      "label": "Partition by Spoof Instance (venue)",
      "config": {
        "input_name": "orders",
        "group_by_column": "venue",
        "output_prefix": "orders_by_venue",
        "keys_output_name": "venue_keys",
        "order": "sort"
      }
    },
    {
      "id": "n05",
      "type": "MAP",
      "label": "Per-Instance Analysis (outer)",
      "config": {
        "keys_key": "venue_keys",
        "iteration_ctx_key": "current_venue",
        "dataset_prefix": "orders_by_venue",
        "iteration_dataset_alias": "orders",
        "output_name": "per_instrument",
        "collect_values": [
          "per_book",
          "instance_qty_total"
        ],
        "collect_datasets": [
          "orders"
        ],
        "sub_workflow": {
          "nodes": [
            {
              "id": "s1",
              "type": "GROUP_BY",
              "label": "Partition by Book (inner)",
              "config": {
                "input_name": "orders",
                "group_by_column": "book",
                "output_prefix": "orders_by_book",
                "keys_output_name": "book_keys",
                "order": "sort"
              }
            },
            {
              "id": "s2",
              "type": "MAP",
              "label": "Per-Book Analysis (inner)",
              "config": {
                "keys_key": "book_keys",
                "iteration_ctx_key": "current_book",
                "dataset_prefix": "orders_by_book",
                "iteration_dataset_alias": "orders",
                "output_name": "per_book",
                "collect_values": [
                  "book_qty",
                  "book_order_count"
                ],
                "collect_datasets": [],
                "sub_workflow": {
                  "nodes": [
                    {
                      "id": "t1",
                      "type": "EXTRACT_SCALAR",
                      "label": "Book qty",
                      "config": {
                        "input_name": "orders",
                        "column": "quantity",
                        "reducer": "sum",
                        "output_name": "book_qty"
                      }
                    },
                    {
                      "id": "t2",
                      "type": "EXTRACT_SCALAR",
                      "label": "Book order count",
                      "config": {
                        "input_name": "orders",
                        "column": "order_id",
                        "reducer": "count",
                        "output_name": "book_order_count"
                      }
                    }
                  ],
                  "edges": [
                    {
                      "from": "t1",
                      "to": "t2"
                    }
                  ]
                }
              }
            },
            {
              "id": "s3",
              "type": "EXTRACT_SCALAR",
              "label": "Instance qty total",
              "config": {
                "input_name": "orders",
                "column": "quantity",
                "reducer": "sum",
                "output_name": "instance_qty_total"
              }
            }
          ],
          "edges": [
            {
              "from": "s1",
              "to": "s2"
            },
            {
              "from": "s1",
              "to": "s3"
            }
          ]
        }
      }
    },
    {
      "id": "n06",
      "type": "FEATURE_ENGINE",
      "label": "Feature Engine \u2014 order-book ladder",
      "config": {
        "input_name": "orders",
        "output_name": "orders_features",
        "ops": [
          {
            "op": "window_bucket",
            "time_col": "order_time",
            "interval_ms": 60000,
            "out_col": "minute_bucket"
          },
          {
            "op": "groupby_agg",
            "by": [
              "minute_bucket",
              "side"
            ],
            "aggs": {
              "quantity": "sum",
              "order_id": "count"
            },
            "as": "ladder_long"
          },
          {
            "op": "pivot",
            "index": "minute_bucket",
            "columns": "side",
            "values": "quantity",
            "aggfunc": "sum",
            "as": "ladder"
          }
        ]
      }
    },
    {
      "id": "n07",
      "type": "SIGNAL_CALCULATOR",
      "label": "Signal \u2014 Spoofing",
      "config": {
        "mode": "configure",
        "signal_type": "SPOOFING",
        "input_name": "orders_features",
        "output_name": "orders_signals",
        "params": {
          "cancel_ratio_threshold": 0.5,
          "window": "30m"
        }
      }
    },
    {
      "id": "n08",
      "type": "DATA_HIGHLIGHTER",
      "label": "Highlight Cancelled Orders",
      "config": {
        "input_name": "orders_signals",
        "output_name": "orders_signals_highlighted",
        "rules": [
          {
            "condition": "status == 'CANCELLED'",
            "colour": "#FCA5A5",
            "label": "Cancelled"
          },
          {
            "condition": "_signal_flag == True",
            "colour": "#DC2626",
            "label": "Spoof signal"
          }
        ]
      }
    },
    {
      "id": "n09",
      "type": "DECISION_RULE",
      "label": "Disposition (rules-mode)",
      "config": {
        "input_name": "orders_signals",
        "escalate_threshold": 1,
        "review_threshold": 1,
        "rules": [
          {
            "name": "spoof_signal_fired",
            "when": "{orders_signals._signal_flag.any}",
            "disposition": "ESCALATE",
            "severity": "CRITICAL"
          },
          {
            "name": "high_cancel_volume",
            "when": "{orders.@row_count} > 30",
            "disposition": "REVIEW",
            "severity": "MEDIUM"
          }
        ]
      }
    },
    {
      "id": "n10",
      "type": "SECTION_SUMMARY",
      "label": "Signals Section (templated)",
      "config": {
        "section_name": "spoof_signals",
        "input_name": "orders_signals",
        "mode": "templated",
        "field_bindings": [
          {
            "field": "_signal_flag",
            "agg": "sum"
          },
          {
            "field": "_signal_score",
            "agg": "max"
          },
          {
            "field": "_signal_type",
            "agg": "nunique"
          }
        ],
        "llm_prompt_template": "You are a fixed-income surveillance analyst.\nTrader: {trader_id}  Disposition: {disposition}\nSignal stats:\n{stats}\n\nWrite a one-paragraph summary of the spoofing signals."
      }
    },
    {
      "id": "n11",
      "type": "SECTION_SUMMARY",
      "label": "Orders Fact Pack",
      "config": {
        "section_name": "orders_overview",
        "input_name": "orders",
        "mode": "fact_pack_llm",
        "facts": [
          {
            "name": "order_count",
            "column": "order_id",
            "agg": "count"
          },
          {
            "name": "total_qty",
            "column": "quantity",
            "agg": "sum"
          },
          {
            "name": "instruments",
            "column": "instrument",
            "agg": "unique_values"
          },
          {
            "name": "books",
            "column": "book",
            "agg": "unique_values"
          },
          {
            "name": "cancelled_count",
            "column": "status",
            "agg": "count_where_cancelled"
          }
        ],
        "required_facts": [
          "order_count",
          "cancelled_count"
        ],
        "llm_prompt_template": "You are a fixed-income surveillance analyst.\nTrader: {trader_id}\nFacts (JSON):\n{facts}\n\nWrite a tight 2-paragraph layering / spoofing analysis referencing every fact verbatim."
      }
    },
    {
      "id": "n12",
      "type": "CONSOLIDATED_SUMMARY",
      "label": "Executive Summary",
      "config": {}
    },
    {
      "id": "n13",
      "type": "REPORT_OUTPUT",
      "label": "Generate Excel Report",
      "config": {
        "output_path": "output/fisl_report.xlsx",
        "tabs": [
          {
            "name": "All Orders",
            "dataset": "orders",
            "include_highlights": false
          },
          {
            "name": "Order-Book Ladder",
            "dataset": "ladder",
            "include_highlights": false
          },
          {
            "name": "Spoof Signals",
            "dataset": "orders_signals",
            "include_highlights": true
          },
          {
            "expand_from": "{context.per_instrument}",
            "as": "key",
            "name": "Venue {key}",
            "dataset": "per_instrument_{key}_orders",
            "include_highlights": false
          }
        ]
      }
    }
  ],
  "edges": [
    {
      "from": "n01",
      "to": "n02"
    },
    {
      "from": "n02",
      "to": "n03"
    },
    {
      "from": "n03",
      "to": "n04"
    },
    {
      "from": "n04",
      "to": "n05"
    },
    {
      "from": "n03",
      "to": "n06"
    },
    {
      "from": "n06",
      "to": "n07"
    },
    {
      "from": "n07",
      "to": "n08"
    },
    {
      "from": "n07",
      "to": "n09"
    },
    {
      "from": "n07",
      "to": "n10"
    },
    {
      "from": "n03",
      "to": "n11"
    },
    {
      "from": "n09",
      "to": "n12"
    },
    {
      "from": "n10",
      "to": "n12"
    },
    {
      "from": "n11",
      "to": "n12"
    },
    {
      "from": "n05",
      "to": "n13"
    },
    {
      "from": "n08",
      "to": "n13"
    },
    {
      "from": "n12",
      "to": "n13"
    }
  ]
}
